# ============================================
# My Tasks Dashboard - Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# Command: cp .env.example .env

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Choose ONE of the following database options:

# Option 1: PostgreSQL (Recommended for Production)
# How to get: Install PostgreSQL and create a database
#   macOS: brew install postgresql && brew services start postgresql
#   Linux: sudo apt-get install postgresql
#   Create DB: createdb mytasks
#   Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/mytasks

# Option 2: SQLite (Good for Development/Testing)
# How to get: No installation needed, file-based database
# Uncomment the line below to use SQLite instead:
# DATABASE_URL=sqlite:///mytasks.db

# ============================================
# FLASK CONFIGURATION
# ============================================
# SECRET_KEY: Used for session encryption and security
# How to get: Generate a random secret key
#   Python: python -c "import secrets; print(secrets.token_hex(32))"
#   Or use: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-use-command-above

# FLASK_ENV: Application environment
# Options: development, production
FLASK_ENV=production

# ============================================
# SERVER CONFIGURATION
# ============================================
# HOST: Server bind address
#   0.0.0.0 = Listen on all network interfaces (accessible from network)
#   127.0.0.1 = Listen only on localhost (more secure, local only)
HOST=127.0.0.1

# PORT: Server port number
# Default: 5000 (change if port is already in use)
PORT=5000

# ============================================
# OPTIONAL: IBM CLOUD CONFIGURATION
# ============================================
# Required only if using Pipelines Manager feature
# How to get:
#   1. Install IBM Cloud CLI: https://cloud.ibm.com/docs/cli
#   2. Login: ibmcloud login --sso
#   3. The app will use your CLI authentication automatically
# No additional environment variables needed for IBM Cloud

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your values
# 3. For PostgreSQL:
#    - Install PostgreSQL
#    - Create database: createdb mytasks
#    - Update DATABASE_URL with your credentials
# 4. Generate SECRET_KEY:
#    python -c "import secrets; print(secrets.token_hex(32))"
# 5. Run migrations:
#    python migrate_mute_until.py
#    python migrate_task_fields.py
#    python migrate_task_reminders.py
#    python migrate_jira_settings.py
# 6. Start the app: python app.py
# 7. Open browser: http://localhost:5000

# ============================================
# SECURITY NOTES
# ============================================
# - Never commit .env file to git (it's in .gitignore)
# - Use strong SECRET_KEY in production
# - Use PostgreSQL in production (not SQLite)
# - Keep HOST=127.0.0.1 for local-only access
# - Use HTTPS if exposing to network

# Jira Configuration (Optional - configure in Settings page)
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your-api-token-here
# JIRA_PROJECT_KEY=PROJ